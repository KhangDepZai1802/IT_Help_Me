# Use Supabase Session Pooler for IPv4-only environments.
# Example: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require&uselibpqcompat=true
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require&uselibpqcompat=true"
AUTH_SECRET="generate-a-long-random-secret"
IT_PASSWORD="123456"
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="it-help-me-attachments"
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
